# =============================================================================
# Search Console MCP - Environment Variables
# =============================================================================
# Copy to .env and fill in your values.
# For Vercel: set these in Project Settings → Environment Variables.
# =============================================================================

# -----------------------------------------------------------------------------
# Google Search Console & GA4 (choose one method)
# -----------------------------------------------------------------------------

# Option A: Service account key file path (local development)
# Path to your Google Cloud service account JSON key file.
# Create at: https://console.cloud.google.com/iam-admin/serviceaccounts
# Grant the service account access in Search Console and GA4 (Property Access).
GOOGLE_APPLICATION_CREDENTIALS=path/to/your/service-account-key.json

# Option B: Inline JSON (required for Vercel/serverless – no file system)
# Paste the full contents of your service account JSON key as a single line.
# Same key is used for both Google Search Console and GA4.
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Option C: JWT-style (email + private key)
# GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----"

# -----------------------------------------------------------------------------
# GA4 (Google Analytics 4)
# -----------------------------------------------------------------------------
# Default GA4 Property ID when using serverless (e.g. Vercel).
# Add the service account email to GA4 Admin → Property → Property Access Management.
GA4_PROPERTY_ID=123456789

# -----------------------------------------------------------------------------
# Bing Webmaster Tools
# -----------------------------------------------------------------------------
# API key from https://www.bing.com/webmasters/settings/api
# Optional if you only use Google/GA4.
BING_API_KEY=your-bing-api-key

# -----------------------------------------------------------------------------
# OAuth (optional – for desktop setup flow only, not used on Vercel)
# -----------------------------------------------------------------------------
# Used by `npx search-console-mcp setup` for interactive login.
# Leave unset for serverless; use service account (Option A or B) instead.
# GOOGLE_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-oauth-client-secret
